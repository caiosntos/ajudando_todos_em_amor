{
  "name": "ajudando-todos-em-amor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "migrate": "dotenv -e .env.local -- node-pg-migrate -m migrations",
    "migrate:up": "dotenv -e .env.local -- node-pg-migrate up -m migrations",
    "migrate:down": "dotenv -e .env.local -- node-pg-migrate down -m migrations",
    "seed:admin": "dotenv -e .env.local -- tsx scripts/seed-admin.ts",
    "tunnel": "npx ngrok start ajudando-todos --config ngrok.yml"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.469.0",
    "next": "^15.3.3",
    "pg": "^8.13.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^11.0.0",
    "node-pg-migrate": "^7.8.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "core-js@3.49.0": true
  }
}
